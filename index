<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ACS Digital - Painel de Controle</title>
    <link rel="stylesheet" href="style.css">
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
</head>
<body>

    <div class="app-container">
        
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="logo-icon"><i class="ph-bold ph-heart-beat"></i></div>
                <div>
                    <h1>ACS Digital</h1>
                    <span class="subtitle">Microárea 03 - Guarda-Mor</span>
                </div>
            </div>

            <nav class="sidebar-nav">
                <span class="nav-section-title">Navegação Principal</span>
                <a href="#" class="nav-item active"><i class="ph ph-house"></i> Dashboard</a>
                <a href="#" class="nav-item"><i class="ph ph-users"></i> Famílias</a>
                <a href="#" class="nav-item"><i class="ph ph-map-pin"></i> Visitas</a>
                <a href="#" class="nav-item"><i class="ph ph-chart-bar"></i> Indicadores</a>
                
                <span class="nav-section-title">Atalhos Rápidos</span>
                <a href="#" class="nav-item"><i class="ph ph-user-plus"></i> Novo Cadastro</a>
                <a href="#" class="nav-item"><i class="ph ph-clipboard-text"></i> Ficha de Sintomas</a>
            </nav>

            <div class="sidebar-footer">
                <a href="#" class="nav-item"><i class="ph ph-gear"></i> Configurações</a>
                <div class="sync-status">
                    <i class="ph-bold ph-cloud-check"></i>
                    <span>Sincronizado (Offline)</span>
                </div>
            </div>
        </aside>

        <main class="main-content">
            
            <header class="main-header">
                <div class="welcome-zone">
                    <h2>Bom dia, Gabi.</h2>
                    <p class="current-date" id="live-date">Sábado, 20 de Junho</p>
                </div>
                <div class="search-zone">
                    <i class="ph ph-magnifying-glass search-icon"></i>
                    <input type="text" placeholder="Busca rápida por nome, CPF ou rua..." class="search-input">
                </div>
            </header>

            <section class="overview-section">
                <div class="compact-card">
                    <span class="card-label">Famílias</span>
                    <span class="card-value">142</span>
                    <span class="card-subtext positive">+2 este mês</span>
                </div>
                <div class="compact-card">
                    <span class="card-label">Visitas Mês</span>
                    <span class="card-value">45 <span class="goal">/ 150</span></span>
                    <span class="card-subtext">Meta: 30% concluída</span>
                </div>
                <div class="compact-card">
                    <span class="card-label">Gestantes</span>
                    <span class="card-value">8</span>
                    <span class="card-subtext highlight">2 no 3º trimestre</span>
                </div>
                <div class="compact-card">
                    <span class="card-label">Pendências</span>
                    <span class="card-value text-alert">5</span>
                    <span class="card-subtext">Atualizar hoje</span>
                </div>
            </section>

            <section class="priority-section">
                <div class="section-header">
                    <h3>Visitas Prioritárias</h3>
                    <button class="btn-secondary"><i class="ph ph-plus"></i> Nova Visita</button>
                </div>

                <div class="priority-list">
                    <div class="priority-item">
                        <div class="item-left">
                            <span class="badge-priority high"></span>
                            <div class="patient-info">
                                <span class="patient-condition">Gestante 3º Trimestre</span>
                                <span class="patient-meta">Ana Silva — Rua A, 12</span>
                            </div>
                        </div>
                        <button class="btn-action">Iniciar</button>
                    </div>

                    <div class="priority-item">
                        <div class="item-left">
                            <span class="badge-priority medium"></span>
                            <div class="patient-info">
                                <span class="patient-condition">Hipertenso - Atrasado</span>
                                <span class="patient-meta">João Costa — Rua B, 44</span>
                            </div>
                        </div>
                        <button class="btn-action">Iniciar</button>
                    </div>

                    <div class="priority-item">
                        <div class="item-left">
                            <span class="badge-priority low"></span>
                            <div class="patient-info">
                                <span class="patient-condition">Rotina Mensal</span>
                                <span class="patient-meta">Maria José — Rua C, 10</span>
                            </div>
                        </div>
                        <button class="btn-action">Iniciar</button>
                    </div>
                </div>
            </section>

            <section class="split-section">
                <div class="split-block map-block">
                    <h4>Contexto Geoespacial</h4>
                    <div class="map-placeholder">
                        <i class="ph ph-map-trifold"></i>
                        <p>Exibindo 3 visitas prioritárias no raio atual</p>
                    </div>
                </div>
                <div class="split-block indicators-block">
                    <h4>Indicadores da Semana</h4>
                    <ul class="indicator-ranking">
                        <li>
                            <span class="indicator-name">Vacinação Infantil</span>
                            <span class="indicator-percent">90%</span>
                        </li>
                        <li>
                            <span class="indicator-name">Controle Glicêmico</span>
                            <span class="indicator-percent">75%</span>
                        </li>
                        <li>
                            <span class="indicator-name">Pré-Natal Iniciado</span>
                            <span class="indicator-percent">100%</span>
                        </li>
                    </ul>
                </div>
            </section>

        </main>
    </div>

</body>
</html>
